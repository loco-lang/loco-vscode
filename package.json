{
  "name": "loco-vscode",
  "displayName": "Loco Language Support",
  "description": "Loco language support — syntax highlighting, code completion, document symbols, and diagnostics for the Loco DSL",
  "version": "0.1.0",
  "publisher": "loco-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/loco-lang/loco-vscode"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "loco",
    "exrail",
    "dcc-ex",
    "model railroad"
  ],
  "contributes": {
    "languages": [
      {
        "id": "loco",
        "aliases": [
          "Loco",
          "loco"
        ],
        "extensions": [
          ".loco"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "loco",
        "scopeName": "source.loco",
        "path": "./syntaxes/loco.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "loco",
        "path": "./snippets/loco.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:loco"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "web-tree-sitter": "^0.22.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.85.0",
    "eslint": "^8.50.0",
    "mocha": "^11.7.6",
    "typescript": "^5.3.0"
  }
}
